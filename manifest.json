{
  "manifest_version": 3,
  "name": "Ifconfig IP Copier",
  "version": "1.1.2",
  "description": "Displays your public IP from ifconfig.me and lets you copy it.",
  "permissions": [
    "alarms",
    "clipboardWrite",
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "128.png",
    "32": "128.png",
    "48": "128.png",
    "128": "128.png"
  },
  "action": {
    "default_icon": {
      "16": "128.png",
      "32": "128.png",
      "48": "128.png",
      "128": "128.png"
    },
    "default_popup": "popup.html",
    "default_title": ""
  }
}
